# AWS Deployment Configuration
# GPU Instance + Ollama (Self-hosted Open Models)

# ===========================================
# AWS Region
# ===========================================
AWS_REGION="ap-southeast-1"

# ===========================================
# EC2 Configuration
# ===========================================
# CPU instances (no GPU quota needed):
#   c7i.2xlarge  - 8 vCPU, 16GB RAM, Intel Xeon 4th Gen (~$0.36/hr) - FASTEST CPU
#   c7a.2xlarge  - 8 vCPU, 16GB RAM, AMD EPYC 4th Gen (~$0.31/hr)
#   m7i.xlarge   - 4 vCPU, 16GB RAM (~$0.20/hr) - Budget option
#
# GPU instances (requires GPU quota approval):
#   g4dn.xlarge  - NVIDIA T4 (16GB), 4 vCPU, 16GB RAM (~$0.53/hr)
#   g5.xlarge    - NVIDIA A10G (24GB), 4 vCPU, 16GB RAM (~$1.01/hr)
INSTANCE_TYPE="c7i.2xlarge"
AMI_ID="ami-08d59269edddde222"      # Ubuntu 24.04 LTS (ap-southeast-1)
KEY_PAIR_NAME="rag-platform-key"    # Your EC2 key pair name
EBS_SIZE="100"                      # GB (SSD storage)

# ===========================================
# Network Configuration
# ===========================================
VPC_CIDR="10.0.0.0/16"
SUBNET_CIDR="10.0.1.0/24"

# ===========================================
# Application Configuration
# ===========================================
APP_NAME="rag-platform"
DOMAIN_NAME=""                      # Optional: your domain (e.g., rag.example.com)

# ===========================================
# SSH Access
# ===========================================
# Find your IP: curl -s ifconfig.me
# Leave empty for 0.0.0.0/0 (less secure)
MY_IP=""

# ===========================================
# Tags
# ===========================================
ENVIRONMENT="production"
PROJECT="enterprise-rag"

# ===========================================
# LLM Configuration - Ollama (Self-hosted)
# ===========================================
LLM_PROVIDER="ollama"

# Development models (fast download, good for testing):
#   llama3.2:1b    - 1.3GB download, basic quality, fastest
#   llama3.2:3b    - 2.0GB download, good quality, fast (RECOMMENDED FOR DEV)
#   qwen2.5:1.5b   - 1.0GB download, good quality, fastest
#
# Production models (better quality, larger download):
#   llama3.1:8b    - 4.7GB download, best quality/speed balance
#   mistral:7b     - 4.1GB download, good quality
#   llama3.1:70b-q4 - 40GB download, highest quality (needs 24GB+ VRAM)
OLLAMA_MODEL="llama3.2:1b"
