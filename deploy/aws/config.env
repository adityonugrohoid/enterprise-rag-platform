# AWS Deployment Configuration
# Copy this file and fill in your values

# AWS Region
AWS_REGION="ap-southeast-1"

# EC2 Configuration
# Free Tier eligible instances (verified for your account):
#   m7i-flex.large  - 2 vCPU, 8GB RAM (recommended)
#   c7i-flex.large  - 2 vCPU, 4GB RAM
#   t3.small        - 2 vCPU, 2GB RAM
#   t3.micro        - 2 vCPU, 1GB RAM (testing only)
INSTANCE_TYPE="m7i-flex.large"     # 2 vCPU, 8GB RAM - Free Tier eligible
AMI_ID="ami-08d59269edddde222"      # Ubuntu 24.04 LTS (ap-southeast-1)
KEY_PAIR_NAME="rag-platform-key"    # Your EC2 key pair name
EBS_SIZE="100"                      # GB

# Network Configuration
VPC_CIDR="10.0.0.0/16"
SUBNET_CIDR="10.0.1.0/24"

# Application Configuration
APP_NAME="rag-platform"
DOMAIN_NAME=""                      # Optional: your domain (e.g., rag.example.com)

# SSH Access - IMPORTANT: Set this to your IP for security
# Find your IP: curl -s ifconfig.me
MY_IP=""                            # e.g., "203.0.113.50/32" - leave empty for 0.0.0.0/0 (less secure)

# Tags
ENVIRONMENT="production"
PROJECT="enterprise-rag"

# ===========================================
# LLM Provider Configuration
# ===========================================
# Options: "ollama" (self-hosted) or "bedrock" (AWS managed)
LLM_PROVIDER="bedrock"

# Bedrock Configuration (only used if LLM_PROVIDER="bedrock")
# Available models:
#   - meta.llama3-1-8b-instruct-v1:0 (recommended, balanced)
#   - meta.llama3-1-70b-instruct-v1:0 (higher quality)
#   - amazon.titan-text-lite-v1 (cheapest)
#   - amazon.titan-text-express-v1 (good quality)
#   - mistral.mistral-7b-instruct-v0:2 (fast)
BEDROCK_MODEL="meta.llama3-1-8b-instruct-v1:0"

# Ollama Configuration (only used if LLM_PROVIDER="ollama")
OLLAMA_MODEL="llama3.2:1b"
