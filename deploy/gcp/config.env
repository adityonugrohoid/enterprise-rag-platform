# GCP Deployment Configuration
# GPU Instance + Ollama (Self-hosted Open Models)

# ===========================================
# GCP Project Configuration
# ===========================================
GCP_PROJECT_ID=""                          # Required: your GCP project ID
GCP_ZONE="asia-southeast1-b"               # Zone (Singapore)
GCP_REGION="asia-southeast1"               # Region

# ===========================================
# Compute Engine - GPU Instance
# ===========================================
# GPU machine types:
#   g2-standard-4  - NVIDIA L4 (24GB), 4 vCPU, 16GB RAM (~$0.70/hr)
#   g2-standard-8  - NVIDIA L4 (24GB), 8 vCPU, 32GB RAM (~$1.00/hr)
#   n1-standard-4 + T4 - NVIDIA T4 (16GB), 4 vCPU, 15GB RAM (~$0.55/hr)
MACHINE_TYPE="g2-standard-4"
GPU_TYPE="nvidia-l4"                       # nvidia-l4 for g2, nvidia-tesla-t4 for n1
GPU_COUNT="1"
BOOT_DISK_SIZE="100"                       # GB (SSD)
IMAGE_FAMILY="ubuntu-2404-lts-amd64"
IMAGE_PROJECT="ubuntu-os-cloud"

# ===========================================
# Application Configuration
# ===========================================
INSTANCE_NAME="rag-platform"
NETWORK_TAG="rag-platform"

# ===========================================
# SSH Configuration
# ===========================================
# SSH key will be managed by gcloud
SSH_USER="ubuntu"

# ===========================================
# LLM Configuration - Ollama (Self-hosted)
# ===========================================
LLM_PROVIDER="ollama"

# Development models (fast download, good for testing):
#   llama3.2:1b    - 1.3GB download, basic quality, fastest
#   llama3.2:3b    - 2.0GB download, good quality, fast (RECOMMENDED FOR DEV)
#   qwen2.5:1.5b   - 1.0GB download, good quality, fastest
#
# Production models (better quality, larger download):
#   llama3.1:8b    - 4.7GB download, best quality/speed balance
#   llama3.1:70b-q4 - 40GB download, highest quality (L4 can handle this)
OLLAMA_MODEL="llama3.2:3b"

# ===========================================
# Tags
# ===========================================
ENVIRONMENT="production"
PROJECT="enterprise-rag"
